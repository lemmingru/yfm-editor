{
  "name": "yfm-editor-monorepo",
  "private": true,
  "version": "0.3.0",
  "description": "Monorepo for the YFM editor: a shared platform-agnostic core plus a Tauri desktop app (a VS Code extension is planned).",
  "license": "MIT",
  "author": "Alexey Melekhin",
  "repository": {
    "type": "git",
    "url": "https://github.com/alxmelekhin/yfm-editor.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @yfm-editor/desktop",
    "build": "npm run build -w @yfm-editor/desktop",
    "preview": "npm run preview -w @yfm-editor/desktop",
    "app": "npm run app -w @yfm-editor/desktop",
    "app:build": "npm run app:build -w @yfm-editor/desktop",
    "tauri": "npm run tauri -w @yfm-editor/desktop",
    "tauri:doctor": "npm run tauri:doctor -w @yfm-editor/desktop",
    "test": "npm run test --workspaces --if-present",
    "test:rust": "cargo test --manifest-path packages/desktop/src-tauri/Cargo.toml",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
