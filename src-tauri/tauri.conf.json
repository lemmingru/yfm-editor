{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "YFM Editor",
  "version": "0.2.0",
  "identifier": "com.alxmelekhin.yfmeditor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "YFM Editor",
        "width": 1100,
        "height": 760,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown Document",
        "description": "Markdown / YFM document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
